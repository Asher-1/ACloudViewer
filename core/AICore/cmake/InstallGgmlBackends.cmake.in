# Generated by AICore/CMakeLists.txt — run via install(SCRIPT) during cmake --install.
cmake_minimum_required(VERSION 3.16)

set(_copy_script "@_AICORE_COPY_GGML_SCRIPT@")
set(_dest "${CMAKE_INSTALL_PREFIX}/@_AICORE_GGML_INSTALL_SUBDIR@")
set(_runtime_dir "@GGML_RUNTIME_LIB_DIR@")
set(_backend_dir "@GGML_BACKEND_DIR@")
set(_lib_prefix "@CMAKE_SHARED_LIBRARY_PREFIX@")
set(_shared_suffix "@CMAKE_SHARED_LIBRARY_SUFFIX@")
set(_module_suffix "@GGML_MODULE_SUFFIX@")
set(_gpu_pipe "@_AICORE_GPU_PIPE@")
set(_cpu_all_variants "@_AICORE_CPU_ALL_VARIANTS@")

if(NOT IS_DIRECTORY "${_runtime_dir}")
    message(FATAL_ERROR "InstallGgmlBackends: ggml runtime dir missing: ${_runtime_dir}")
endif()
if(NOT IS_DIRECTORY "${_backend_dir}")
    message(FATAL_ERROR "InstallGgmlBackends: ggml backend dir missing: ${_backend_dir}")
endif()

# No quotes around -D values: nested cmake -P treats quotes as part of the path.
execute_process(COMMAND "@CMAKE_COMMAND@"
    -DCOPY_CORE_SHARED=ON
    -DGGML_BACKEND_DIR=${_runtime_dir}
    -DDEST_DIR=${_dest}
    -DLIB_PREFIX=${_lib_prefix}
    -DLIB_SUFFIX=${_shared_suffix}
    -P ${_copy_script}
    RESULT_VARIABLE _core_result
    ERROR_VARIABLE _core_error)
if(_core_result)
    message(FATAL_ERROR "InstallGgmlBackends: core copy failed: ${_core_error}")
endif()

set(_backend_args
    -DCOPY_BACKEND_MODULES=ON
    -DGGML_BACKEND_DIR=${_backend_dir}
    -DDEST_DIR=${_dest}
    -DLIB_PREFIX=${_lib_prefix}
    -DLIB_SUFFIX=${_module_suffix}
    -DGPU_FILES_PIPE=${_gpu_pipe})
if(_cpu_all_variants STREQUAL "ON")
    list(APPEND _backend_args -DCPU_ALL_VARIANTS=ON)
endif()
list(APPEND _backend_args -P ${_copy_script})
execute_process(COMMAND "@CMAKE_COMMAND@" ${_backend_args}
    RESULT_VARIABLE _backend_result
    ERROR_VARIABLE _backend_error)
if(_backend_result)
    message(FATAL_ERROR "InstallGgmlBackends: backend copy failed: ${_backend_error}")
endif()
