digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="ccCameraSensor::LensDistortion\lParameters",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structccCameraSensor_1_1LensDistortionParameters.html",tooltip="Lens distortion parameters (interface)"];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
