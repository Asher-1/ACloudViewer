  Node0 -> Node2 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node2 [label="ccCameraSensor::RadialDistortion\lParameters",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structccCameraSensor_1_1RadialDistortionParameters.html",tooltip="Simple radial distortion model."];
  Node2 -> Node3 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node3 [label="ccCameraSensor::Extended\lRadialDistortionParameters",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structccCameraSensor_1_1ExtendedRadialDistortionParameters.html",tooltip="Extended radial distortion model."];
}
