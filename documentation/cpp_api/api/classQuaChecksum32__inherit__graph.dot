digraph "QuaChecksum32"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="QuaChecksum32",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="Checksum interface."];
  Node1 -> Node2 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node2 [label="QuaAdler32",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classQuaAdler32.html",tooltip="Adler32 checksum."];
  Node1 -> Node3 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node3 [label="QuaCrc32",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classQuaCrc32.html",tooltip="CRC32 checksum."];
}
