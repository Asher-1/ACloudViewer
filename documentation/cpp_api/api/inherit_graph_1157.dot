digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="QuaChecksum32",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classQuaChecksum32.html",tooltip="Checksum interface."];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node1 [label="QuaAdler32",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classQuaAdler32.html",tooltip="Adler32 checksum."];
  Node0 -> Node2 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node2 [label="QuaCrc32",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classQuaCrc32.html",tooltip="CRC32 checksum."];
}
