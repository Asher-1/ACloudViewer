digraph "graphdef"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="graphdef",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip=" "];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" vrinfo" ,fontname="Helvetica"];
  Node2 [label="vrinfodef",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structvrinfodef.html",tooltip=" "];
  Node3 -> Node2 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" edegrees" ,fontname="Helvetica"];
  Node3 [label="vedegreedef",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structvedegreedef.html",tooltip=" "];
  Node4 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" rinfo" ,fontname="Helvetica"];
  Node4 [label="rinfodef",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structrinfodef.html",tooltip=" "];
  Node5 -> Node4 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" edegrees" ,fontname="Helvetica"];
  Node5 [label="edegreedef",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structedegreedef.html",tooltip=" "];
  Node1 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" coarser\nfiner" ,fontname="Helvetica"];
  Node6 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" nrinfo" ,fontname="Helvetica"];
  Node6 [label="nrinfodef",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structnrinfodef.html",tooltip=" "];
}
