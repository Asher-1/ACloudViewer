digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="CameraRepresentation",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classCameraRepresentation.html",tooltip="Interface for E57 camera representation."];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node1 [label="VisualReferenceRepresentation",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classVisualReferenceRepresentation.html",tooltip=" "];
  Node1 -> Node2 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node2 [label="SphericalRepresentation",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classSphericalRepresentation.html",tooltip=" "];
  Node2 -> Node3 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node3 [label="CylindricalRepresentation",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classCylindricalRepresentation.html",tooltip=" "];
  Node2 -> Node4 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node4 [label="PinholeRepresentation",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classPinholeRepresentation.html",tooltip=" "];
}
