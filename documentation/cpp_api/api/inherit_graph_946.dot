digraph "Graphical Class Hierarchy"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  rankdir="LR";
  Node0 [label="LasField",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structLasField.html",tooltip="LAS field descriptor."];
  Node0 -> Node1 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node1 [label="ExtraLasField",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$structExtraLasField.html",tooltip="Custom (\"Extra bytes\") field (EVLR)"];
}
