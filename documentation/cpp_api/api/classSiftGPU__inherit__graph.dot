  Node1 -> Node4 [dir="back",color="midnightblue",fontsize="10",style="solid",fontname="Helvetica"];
  Node4 [label="SiftGPUEX",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classSiftGPUEX.html",tooltip=" "];
