digraph "E57ScanHeader"
{
 // LATEX_PDF_SIZE
  edge [fontname="Helvetica",fontsize="10",labelfontname="Helvetica",labelfontsize="10"];
  node [fontname="Helvetica",fontsize="10",shape=record];
  Node1 [label="E57ScanHeader",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip="E57 scan useful header information (minimal set for ACloudViewer only ;)"];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" intensityLimits" ,fontname="Helvetica"];
  Node2 [label="IntensityLimits",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classIntensityLimits.html",tooltip=" "];
  Node3 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" colorLimits" ,fontname="Helvetica"];
  Node3 [label="ColorLimits",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classColorLimits.html",tooltip=" "];
  Node4 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" pointFields" ,fontname="Helvetica"];
  Node4 [label="PointStandardizedFieldsAvailable",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classPointStandardizedFieldsAvailable.html",tooltip=" "];
  Node5 -> Node4 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" columnIndexMaximum\nrowIndexMaximum" ,fontname="Helvetica"];
  Node5 [label="uint32_t",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
  Node6 -> Node4 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" returnMaximum" ,fontname="Helvetica"];
  Node6 [label="uint8_t",height=0.2,width=0.4,color="grey75", fillcolor="white", style="filled",tooltip=" "];
}
