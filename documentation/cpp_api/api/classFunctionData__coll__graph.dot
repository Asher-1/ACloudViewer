  Node1 [label="FunctionData\< Degree,\l Real \>",height=0.2,width=0.4,color="black", fillcolor="grey75", style="filled", fontcolor="black",tooltip=" "];
  Node2 -> Node1 [dir="back",color="darkorchid3",fontsize="10",style="dashed",label=" baseFunctions" ,fontname="Helvetica"];
