  Node3 -> Node2 [dir="back",color="orange",fontsize="10",style="dashed",label=" \< Degree+1 \>" ,fontname="Helvetica"];
  Node3 [label="PPolynomial\< Degree \>",height=0.2,width=0.4,color="black", fillcolor="white", style="filled",URL="$classPPolynomial.html",tooltip=" "];
